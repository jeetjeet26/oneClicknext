# ==========================================
# P11 Platform Root Configuration
# ==========================================

# Supabase
# Use the modern publishable key when available. Legacy anon keys are
# still supported for compatibility.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...legacy-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google / Maps
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Search / Scraping
SERPAPI_API_KEY=serpapi-key
APIFY_API_TOKEN=apify-token

# Messaging / Email
TELNYX_API_KEY=telnyx-key
TELNYX_PHONE_NUMBER=+15555555555
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@example.com

# Data Engine
DATA_ENGINE_URL=http://localhost:8000
DATA_ENGINE_API_KEY=replace-with-random-secret

# GEO / Audits
GEO_AUDIT_MODE=natural
GEO_ENABLE_WEB_SEARCH=true

# App / Cron
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
INTERNAL_API_KEY=replace-with-random-internal-secret
CRON_SECRET=replace-with-random-secret

# Google OAuth / Webhooks
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALENDAR_WEBHOOK_URL=https://your-public-app.example.com/api/lumaleasing/calendar/webhook
GMAIL_WATCH_TOPIC=projects/your-project/topics/gmail-watch

# SiteForge / WordPress Deploy
CLOUDWAYS_API_KEY=cloudways-api-key
CLOUDWAYS_EMAIL=you@example.com
CLOUDWAYS_CLOUD=do
CLOUDWAYS_REGION=nyc3
CLOUDWAYS_INSTANCE_TYPE=1GB
CLOUDWAYS_APPLICATION=wordpress
SITEFORGE_WP_URL=https://your-wordpress-site.example.com
SITEFORGE_WP_USERNAME=admin
SITEFORGE_WP_APP_PASSWORD=wp-application-password

# Optional real-provider local smoke toggles
SITEFORGE_REAL_DEPLOY_SMOKE=0
LUMALEASING_REAL_SMOKE=0
LUMALEASING_REAL_SMOKE_API_KEY=replace-with-seeded-property-api-key
