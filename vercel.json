{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "git": {
    "deploymentEnabled": true
  },
  "crons": [
    {
      "path": "/api/workflows/process",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/sync-reviews",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/tours/reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/sync-ads",
      "schedule": "0 */6 * * *"
    }
  ]
}




