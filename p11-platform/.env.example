# ==========================================
# P11 Platform Root Configuration
# ==========================================

# Supabase
# Use the modern publishable key when available. Legacy anon keys are
# still supported for compatibility.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...legacy-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google / Maps
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Search / Scraping
SERPAPI_API_KEY=serpapi-key
APIFY_API_TOKEN=apify-token

# Messaging / Email
TELNYX_API_KEY=telnyx-key
TELNYX_PHONE_NUMBER=+15555555555
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@example.com

# Data Engine
DATA_ENGINE_URL=http://localhost:8000
DATA_ENGINE_API_KEY=replace-with-random-secret

# GEO / Audits
GEO_AUDIT_MODE=natural
GEO_ENABLE_WEB_SEARCH=true

# App / Cron
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
INTERNAL_API_KEY=replace-with-random-internal-secret
CRON_SECRET=replace-with-random-secret

# Google OAuth / Webhooks
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALENDAR_WEBHOOK_URL=https://your-public-app.example.com/api/lumaleasing/calendar/webhook
GMAIL_WATCH_TOPIC=projects/your-project/topics/gmail-watch

# SiteForge / WordPress Deploy
CLOUDWAYS_API_KEY=cloudways-api-key
CLOUDWAYS_EMAIL=you@example.com
CLOUDWAYS_CLOUD=do
CLOUDWAYS_REGION=nyc3
CLOUDWAYS_INSTANCE_TYPE=1GB
CLOUDWAYS_APPLICATION=wordpress
SITEFORGE_WP_URL=https://your-wordpress-site.example.com
SITEFORGE_WP_USERNAME=admin
SITEFORGE_WP_APP_PASSWORD=wp-application-password
# Optional overrides (defaults shown)
# SITEFORGE_CLAUDE_MODEL=claude-sonnet-4-20250514
# SITEFORGE_EMBEDDING_MODEL=text-embedding-3-small
# SITEFORGE_WP_MENU_LOCATION=primary
# SITEFORGE_DISCOVERY_TIMEOUT_MS=10000

# Optional real-provider local smoke toggles
SITEFORGE_REAL_DEPLOY_SMOKE=0
LUMALEASING_REAL_SMOKE=0
LUMALEASING_REAL_SMOKE_API_KEY=replace-with-seeded-property-api-key

# ForgeStudio social pipeline
# Required to encrypt social tokens/app secrets at rest (no default; generate with `openssl rand -hex 32`)
ENCRYPTION_KEY=replace-with-random-32-byte-secret
# Optional: dedicated HMAC secret for OAuth state (falls back to SUPABASE_SERVICE_ROLE_KEY)
# FORGESTUDIO_OAUTH_STATE_SECRET=replace-with-random-secret
# Social app credentials (per-property values can instead be stored via the social config UI)
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
# Optional: route ForgeStudio generation through the Vercel AI Gateway (falls back to OPENAI_API_KEY)
# AI_GATEWAY_API_KEY=
# Optional: override the generation model (default gpt-4o-mini; use provider/model with the gateway)
# FORGESTUDIO_GENERATION_MODEL=openai/gpt-4o-mini
# Per-channel launch gates: a channel publishes only after its app review and
# real-provider smoke pass. Set to 1/true to enable.
FORGESTUDIO_CHANNEL_INSTAGRAM_ENABLED=1
FORGESTUDIO_CHANNEL_FACEBOOK_ENABLED=1
FORGESTUDIO_CHANNEL_LINKEDIN_ENABLED=1
FORGESTUDIO_CHANNEL_TIKTOK_ENABLED=0
FORGESTUDIO_CHANNEL_X_ENABLED=0
# Local publication worker loop (scripts/forgestudio-worker.mjs)
# WORKER_BASE_URL=http://localhost:3000
# WORKER_INTERVAL_MS=30000
