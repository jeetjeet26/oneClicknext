{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p $PORT",
    "lint": "eslint",
    "lint:foundation": "node ./scripts/foundation-lint.mjs",
    "schema:types:stamp": "node ./scripts/stamp-supabase-types-version.mjs",
    "check:schema-types-sync": "node ./scripts/check-schema-types-sync.mjs",
    "check:schema-truth": "npm run check:schema-types-sync && node ./scripts/check-schema-truth.mjs && node ./scripts/check-rls-policy-guards.mjs",
    "check:runtime-config-hardening": "node ./scripts/check-runtime-config-hardening.mjs",
    "test": "vitest run",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "test:watch": "vitest",
    "typecheck:foundation": "node ./scripts/foundation-typecheck.mjs",
    "check:foundation": "npm run check:schema-truth && node ./scripts/check-foundation-trust-boundaries.mjs && npm run check:runtime-config-hardening && npm test && npm run lint:foundation && npm run typecheck:foundation",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.24.1",
    "@langchain/community": "^1.0.7",
    "@langchain/openai": "^1.1.3",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.0",
    "cheerio": "^1.1.0",
    "date-fns": "^4.1.0",
    "google-auth-library": "^10.5.0",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "langchain": "^1.1.5",
    "lucide-react": "^0.561.0",
    "next": "16.0.10",
    "openai": "^6.10.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-is": "^19.2.3",
    "recharts": "^3.5.1",
    "resend": "^6.5.2",
    "sonner": "^1.7.1",
    "unpdf": "^1.4.0",
    "uuid": "^11.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
